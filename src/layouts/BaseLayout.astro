---
import { withBase } from '../lib/paths';
import { g1SignupHref } from '../lib/g1CampaignLinks';

export interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  canonicalPath?: string;
}
const {
  title,
  description = 'The AI-powered operating plane that makes every manager your best manager.',
  activeNav,
  canonicalPath,
} = Astro.props;
const siteOrigin = 'https://cadencehr.ai';
const rawCanonicalPath = canonicalPath ?? Astro.url.pathname;
const cleanCanonicalPath = rawCanonicalPath.replace(/\.html$/, '');
const normalizedCanonicalPath =
  cleanCanonicalPath === '/'
    ? '/'
    : `/${cleanCanonicalPath.replace(/^\/+/, '').replace(/\/+$/, '')}`;
const canonicalUrl = new URL(normalizedCanonicalPath, siteOrigin).toString();
const socialImagePath = withBase('/screenshots/cadence-homepage-hero-2026-05-16.png');
const socialImageUrl = new URL(socialImagePath, siteOrigin).toString();
const socialImageAlt = 'Cadence dashboard showing manager health, goals, recognition, and culture intelligence.';
const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: title,
  description,
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${siteOrigin}#website`,
    name: 'Cadence',
    url: siteOrigin,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Cadence',
    url: siteOrigin,
  },
};
const pageSchemaJson = JSON.stringify(pageSchema).replace(/</g, '\\u003c');
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonicalUrl}>
<meta property="og:type" content="website">
<meta property="og:site_name" content="Cadence">
<meta property="og:url" content={canonicalUrl}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:image" content={socialImageUrl}>
<meta property="og:image:width" content="1600">
<meta property="og:image:height" content="1000">
<meta property="og:image:alt" content={socialImageAlt}>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={socialImageUrl}>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href={withBase('/css/cadence.css')}>
<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')}>
<link rel="icon" type="image/x-icon" href={withBase('/favicon.ico')}>
<link rel="apple-touch-icon" sizes="180x180" href={withBase('/apple-touch-icon.png')}>
<link rel="manifest" href={withBase('/site.webmanifest')}>
<meta name="theme-color" content="#1E3A5F">
<script type="application/ld+json" set:html={pageSchemaJson}></script>
<!-- Privacy-friendly analytics by Plausible -->
<script async src="https://plausible.io/js/pa-y43F0IpV5uMSLp_dayM-v.js"></script>
<script>
 window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
 plausible.init()
</script>
<slot name="head" />
</head>
<body>

<!-- NAV -->
<nav id="main-nav">
  <div class="nav-inner">
    <a href={withBase('/')} class="nav-logo">Cadence</a>
    <ul class="nav-links">
      <li><a href={withBase('/product')} class={activeNav === 'product' ? 'active' : ''}>Product</a></li>
      <li><a href={withBase('/solutions')} class={activeNav === 'solutions' ? 'active' : ''}>Solutions</a></li>
      <li><a href={withBase('/compare')} class={activeNav === 'compare' ? 'active' : ''}>Compare</a></li>
      <li><a href={withBase('/pricing')} class={activeNav === 'pricing' ? 'active' : ''}>Pricing</a></li>
      <li><a href={withBase('/resources')} class={activeNav === 'resources' ? 'active' : ''}>Resources</a></li>
    </ul>
    <div class="nav-actions">
      <span class="beta-pill"><span class="beta-dot"></span>Live access</span>
      <a href="https://app.cadencehr.ai/" class="btn-signin">Sign in</a>
      <a href={g1SignupHref('home_nav', 'cta')} class="btn-demo">Start free trial</a>
    </div>
  </div>
</nav>

<slot />

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div>
        <span class="footer-logo">Cadence</span>
        <p class="footer-tagline">Management by design, not by luck. The AI-powered operating plane for the new shape of work.</p>
        <p class="footer-contact"><a href="mailto:demo@cadencehr.ai">demo@cadencehr.ai</a></p>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>Product</h4>
          <a href={withBase('/product')}>Platform Overview</a>
          <a href={withBase('/product#one-on-ones')}>1:1 Engine</a>
          <a href={withBase('/product#goals')}>Goals &amp; OKRs</a>
          <a href={withBase('/product#personality-intelligence')}>Personality Intelligence</a>
          <a href={withBase('/product#nine-box')}>9-Box</a>
          <a href={withBase('/product#culture-scorecard')}>Culture Scorecard</a>
        </div>
        <div class="footer-col">
          <h4>Solutions</h4>
          <a href={withBase('/solutions#individual-contributors')}>For ICs</a>
          <a href={withBase('/solutions#managers')}>For Managers</a>
          <a href={withBase('/solutions#senior-leaders')}>For Leaders</a>
          <a href={withBase('/solutions#chro')}>For CHROs</a>
          <a href={withBase('/solutions#ceo')}>For CEOs</a>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <a href={withBase('/about')}>About</a>
          <a href={withBase('/resources#manifesto')}>Manifesto</a>
          <a href="https://app.cadencehr.ai/signup?intent=self-serve&source=apex-footer">Start free trial</a>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <a href={withBase('/resources')}>All Resources</a>
          <a href={withBase('/compare')}>vs. Competitors</a>
          <a href={withBase('/resources#manifesto')}>Management Manifesto</a>
        </div>
        <div class="footer-col">
          <h4>Trust</h4>
          <a href={withBase('/security')}>Security</a>
          <a href={withBase('/security#privacy')}>Privacy</a>
          <a href={withBase('/security#compliance')}>Compliance</a>
          <a href={withBase('/accessibility')}>Accessibility</a>
          <a href={withBase('/pricing')}>Pricing</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Cadence. Built for the new shape of work.</span>
      <span style="font-size:11px;opacity:0.7;">Self-serve workspace access starts through the Cadence signup funnel.</span>
    </div>
  </div>
</footer>

<script>
const nav = document.getElementById('main-nav');
window.addEventListener('scroll', () => {
  nav!.classList.toggle('scrolled', window.scrollY > 10);
}, { passive: true });

const fadeEls = document.querySelectorAll('.fade-up');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) { (entry.target as HTMLElement).classList.add('visible'); observer.unobserve(entry.target); }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
fadeEls.forEach(el => observer.observe(el));
setTimeout(() => {
  fadeEls.forEach(el => {
    if (el.getBoundingClientRect().top < window.innerHeight) el.classList.add('visible');
  });
}, 50);
</script>

</body>
</html>
