---
import BaseLayout from './BaseLayout.astro';
import { withBase } from '../lib/paths';

const { frontmatter } = Astro.props;
const title = frontmatter.title as string;
const description = frontmatter['meta-description'] as string;
const canonicalPath = frontmatter.slug as string;
const canonicalUrl = `https://cadencehr.ai${canonicalPath}`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  mainEntityOfPage: canonicalUrl,
  author: { '@type': 'Organization', name: 'Cadence' },
  publisher: { '@type': 'Organization', name: 'Cadence', url: 'https://cadencehr.ai' },
};
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} activeNav="resources" structuredData={articleSchema}>
  <main class="article-shell">
    <div class="container article-container">
      <nav class="article-breadcrumb" aria-label="Breadcrumb">
        <a href={withBase('/resources')}>Resources</a><span aria-hidden="true">/</span><span>{title}</span>
      </nav>
      <article class="article-content">
        <slot />
      </article>
    </div>
  </main>
</BaseLayout>

<style>
  .article-shell { background: var(--gray-50); padding: 56px 0 80px; }
  .article-container { max-width: 860px; }
  .article-breadcrumb { display: flex; gap: 8px; color: var(--gray-500); font-size: 14px; margin-bottom: 28px; }
  .article-breadcrumb a { color: var(--secondary); font-weight: 600; }
  .article-content { background: white; border: 1px solid var(--gray-100); border-radius: 16px; box-shadow: 0 8px 30px rgba(30,58,95,.06); padding: 48px; }
  .article-content :global(h1) { color: var(--primary); font-size: clamp(32px, 4vw, 48px); letter-spacing: -.035em; line-height: 1.08; margin: 0 0 28px; }
  .article-content :global(h2) { color: var(--primary); font-size: 28px; line-height: 1.2; margin: 42px 0 16px; }
  .article-content :global(h3) { color: var(--primary); font-size: 21px; line-height: 1.3; margin: 30px 0 12px; }
  .article-content :global(p), .article-content :global(li) { color: var(--gray-700); font-size: 17px; line-height: 1.75; }
  .article-content :global(p), .article-content :global(ul), .article-content :global(ol), .article-content :global(table), .article-content :global(blockquote) { margin: 0 0 22px; }
  .article-content :global(a) { color: var(--secondary); text-decoration: underline; text-underline-offset: 3px; }
  .article-content :global(blockquote) { border-left: 4px solid var(--accent); color: var(--primary); padding: 14px 20px; background: rgba(245,166,35,.08); }
  .article-content :global(table) { width: 100%; border-collapse: collapse; font-size: 15px; }
  .article-content :global(th), .article-content :global(td) { border: 1px solid var(--gray-100); padding: 12px; text-align: left; vertical-align: top; }
  .article-content :global(th) { background: var(--gray-50); color: var(--primary); }
  @media (max-width: 640px) { .article-shell { padding: 32px 0 48px; } .article-content { padding: 28px 22px; } }
</style>
