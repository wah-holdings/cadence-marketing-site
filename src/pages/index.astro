---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';
---
<style>
/* ── HOME-SPECIFIC ── */
.hero-light { padding: 80px 0 0; overflow: hidden; }
.hero-inner {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
}
.hero-content { padding-bottom: 80px; }
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(74,144,217,0.1);
  color: var(--secondary-dark);
  font-size: 12px;
  font-weight: 600;
  padding: 5px 14px;
  border-radius: 100px;
  margin-bottom: 20px;
  border: 1px solid rgba(74,144,217,0.2);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}
.hero h1 {
  font-size: clamp(36px, 4.5vw, 54px);
  font-weight: 900;
  line-height: 1.08;
  letter-spacing: -0.03em;
  color: var(--primary);
  margin-bottom: 20px;
}
.hero h1 em { font-style: italic; color: var(--secondary); }
.hero-sub { font-size: 18px; font-weight: 500; color: var(--gray-700); line-height: 1.5; margin-bottom: 14px; }
.hero-body { font-size: 15px; color: var(--gray-500); line-height: 1.75; margin-bottom: 32px; max-width: 480px; }
.hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 36px; }
.social-proof { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--gray-500); }
.social-proof-avatars { display: flex; }
.social-proof-avatars span {
  width: 30px; height: 30px;
  border-radius: 50%;
  border: 2px solid white;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700;
  margin-left: -8px; color: white;
}
.social-proof-avatars span:first-child { margin-left: 0; }
.av1 { background: #4A90D9; }
.av2 { background: #10B981; }
.av3 { background: #F5A623; }
.av4 { background: #8B5CF6; }
.hero-mockup-wrap { position: relative; padding-top: 20px; }
.hero-mockup-frame {
  border-radius: 0 0 12px 12px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(30,58,95,0.18), 0 4px 16px rgba(30,58,95,0.1);
}
.hero-mockup-shot {
  width: 100%;
  height: auto;
  aspect-ratio: 7 / 4;
  display: block;
  object-fit: cover;
  object-position: center;
  background: var(--primary);
}
.browser-chrome {
  background: #E8ECEF;
  border-radius: 12px 12px 0 0;
  padding: 10px 14px 0;
  display: flex; align-items: center; gap: 8px;
}
.chrome-dots { display: flex; gap: 5px; }
.chrome-dots span { width: 11px; height: 11px; border-radius: 50%; }
.dot-red { background: #FF5F57; }
.dot-yellow { background: #FEBC2E; }
.dot-green { background: #28C840; }
.chrome-bar {
  flex: 1; background: white; border-radius: 5px; height: 22px;
  margin-left: 8px; display: flex; align-items: center;
  padding: 0 10px; font-size: 11px; color: var(--gray-500); gap: 5px;
}
.chrome-bar::before { content: '🔒'; font-size: 9px; }
.app-window {
  background: #F1F4F8;
  border-radius: 0 0 12px 12px;
  overflow: hidden;
  display: flex;
  box-shadow: 0 20px 60px rgba(30,58,95,0.18), 0 4px 16px rgba(30,58,95,0.1);
  min-height: 380px;
}
.app-sidebar { width: 180px; background: var(--primary); flex-shrink: 0; padding: 16px 0; }
.sidebar-logo { padding: 0 16px 16px; font-size: 15px; font-weight: 800; color: white; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 8px; }
.sidebar-nav a {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 16px; font-size: 12px;
  color: rgba(255,255,255,0.6); text-decoration: none;
  border-radius: 6px; margin: 0 6px; transition: background 0.15s;
  font-weight: 500;
}
.sidebar-nav a.active { background: rgba(255,255,255,0.12); color: white; }
.app-main { flex: 1; padding: 20px; display: flex; flex-direction: column; gap: 14px; background: var(--off-white); }
.app-title { font-size: 15px; font-weight: 700; color: var(--primary); }
.app-sub { font-size: 11px; color: var(--gray-500); }
.ai-badge {
  display: inline-flex; align-items: center; gap: 5px;
  background: linear-gradient(135deg, #7C3AED, #4A90D9);
  color: white; font-size: 10px; font-weight: 700;
  padding: 4px 10px; border-radius: 100px;
}
.scorecard-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.score-card { background: white; border-radius: 8px; padding: 12px 14px; border: 1px solid var(--gray-100); }
.score-label { font-size: 10px; color: var(--gray-500); font-weight: 500; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
.score-value { font-size: 24px; font-weight: 800; line-height: 1; }
.score-unit { font-size: 12px; font-weight: 500; color: var(--gray-500); }
.score-trend { font-size: 10px; font-weight: 600; margin-top: 3px; }
.score-blue .score-value { color: var(--secondary); }
.score-blue .score-trend { color: var(--secondary); }
.score-green .score-value { color: var(--success); }
.score-green .score-trend { color: var(--success); }
.score-orange .score-value { color: var(--accent); }
.score-orange .score-trend { color: var(--accent); }
.score-red .score-value { color: var(--danger); }
.score-red .score-trend { color: var(--danger); }
.app-meeting-card {
  background: white; border-radius: 8px; padding: 12px 14px;
  border: 1px solid var(--gray-100);
  display: flex; justify-content: space-between; align-items: center;
}
.meeting-info { font-size: 12px; }
.meeting-title { font-weight: 600; color: var(--primary); margin-bottom: 2px; }
.meeting-meta { color: var(--gray-500); }
.meeting-status { font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 100px; background: rgba(16,185,129,0.1); color: var(--success); }
.section-problem { background: var(--primary); padding: 88px 0; color: white; }
.problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; margin-top: 48px; align-items: start; }
.problem-text { font-size: 16px; color: rgba(255,255,255,0.75); line-height: 1.75; }
.problem-text p + p { margin-top: 16px; }
.failure-cards { display: flex; flex-direction: column; gap: 16px; }
.failure-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px; padding: 20px 22px;
  transition: background 0.2s;
}
.failure-card:hover { background: rgba(255,255,255,0.09); }
.failure-icon { width: 36px; height: 36px; border-radius: 8px; background: rgba(245,166,35,0.15); display: flex; align-items: center; justify-content: center; font-size: 16px; margin-bottom: 10px; border: 1px solid rgba(245,166,35,0.25); }
.failure-card h4 { font-size: 14px; font-weight: 700; color: white; margin-bottom: 6px; }
.failure-card p { font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.6; }
.problem-bridge {
  margin-top: 48px; padding-top: 40px;
  border-top: 1px solid rgba(255,255,255,0.1);
  text-align: center; font-size: 18px; font-weight: 600;
  color: rgba(255,255,255,0.85); max-width: 600px;
  margin-left: auto; margin-right: auto;
}
.problem-bridge strong { color: var(--accent); }
.pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 16px; }
.pillar { background: var(--off-white); border-radius: 16px; padding: 32px; border: 1px solid var(--gray-100); }
.pillar-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 18px; }
.pillar-icon-1 { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); }
.pillar-icon-2 { background: rgba(74,144,217,0.1); border: 1px solid rgba(74,144,217,0.2); }
.pillar-icon-3 { background: rgba(139,92,246,0.1); border: 1px solid rgba(139,92,246,0.2); }
.pillar h3 { font-size: 12px; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; }
.pillar h4 { font-size: 19px; font-weight: 700; color: var(--primary); margin-bottom: 10px; }
.pillar p { font-size: 14px; color: var(--gray-500); line-height: 1.65; }
.modules-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
.module-tile {
  background: var(--white); border-radius: 14px; padding: 24px;
  border: 1px solid var(--gray-100);
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  text-decoration: none; display: block;
}
.module-tile:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(30,58,95,0.1); border-color: var(--secondary); }
.module-emoji { font-size: 26px; margin-bottom: 12px; display: block; }
.module-tile h3 { font-size: 14px; font-weight: 700; color: var(--primary); margin-bottom: 6px; }
.module-tile p { font-size: 12px; color: var(--gray-500); line-height: 1.55; }
.module-link { display: inline-flex; align-items: center; gap: 4px; font-size: 12px; font-weight: 600; color: var(--secondary); margin-top: 10px; }
.personas-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
.persona-card { border-radius: 16px; padding: 28px; border: 1px solid var(--gray-100); transition: transform 0.2s, box-shadow 0.2s; text-decoration: none; display: block; }
.persona-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(30,58,95,0.1); }
.persona-ic { background: linear-gradient(135deg, #EFF6FF, #DBEAFE); border-color: #BFDBFE; }
.persona-mgr { background: linear-gradient(135deg, #F0FDF4, #DCFCE7); border-color: #BBF7D0; }
.persona-l2 { background: linear-gradient(135deg, #FFF7ED, #FFEDD5); border-color: #FED7AA; }
.persona-chro { background: linear-gradient(135deg, #F5F3FF, #EDE9FE); border-color: #DDD6FE; }
.persona-avatar { width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; margin-bottom: 16px; background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
.persona-card h3 { font-size: 15px; font-weight: 700; color: var(--primary); margin-bottom: 8px; }
.persona-card p { font-size: 13px; color: var(--gray-700); line-height: 1.6; }
.pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
.pricing-card { border-radius: 16px; border: 1.5px solid var(--gray-200); padding: 32px; background: var(--white); position: relative; transition: all 0.2s; }
.pricing-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(30,58,95,0.1); }
.pricing-card.featured { border-color: var(--secondary); box-shadow: 0 0 0 3px rgba(74,144,217,0.1); }
.pricing-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--secondary); color: white; font-size: 11px; font-weight: 700; padding: 4px 14px; border-radius: 100px; white-space: nowrap; letter-spacing: 0.5px; text-transform: uppercase; }
.pricing-tier { font-size: 12px; font-weight: 700; color: var(--secondary); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 10px; }
.pricing-price { font-size: 40px; font-weight: 900; color: var(--primary); letter-spacing: -1.5px; line-height: 1; margin-bottom: 4px; }
.pricing-price span { font-size: 16px; font-weight: 500; color: var(--gray-500); letter-spacing: 0; }
.pricing-meta { font-size: 12px; color: var(--gray-500); margin-bottom: 20px; }
.pricing-desc { font-size: 14px; color: var(--gray-700); line-height: 1.6; margin-bottom: 20px; }
.pricing-features { list-style: none; display: flex; flex-direction: column; gap: 9px; margin-bottom: 24px; }
.pricing-features li { display: flex; gap: 9px; font-size: 13px; color: var(--gray-700); }
.pricing-features li::before { content: '✓'; font-weight: 700; color: var(--success); flex-shrink: 0; }
.btn-pricing { display: block; text-align: center; font-size: 14px; font-weight: 600; padding: 12px; border-radius: 10px; text-decoration: none; transition: all 0.15s; }
.btn-pricing-primary { background: var(--primary); color: white; }
.btn-pricing-primary:hover { background: var(--primary-dark); }
.btn-pricing-outline { background: transparent; color: var(--primary); border: 2px solid var(--gray-200); }
.btn-pricing-outline:hover { border-color: var(--primary); }
@media (max-width: 1024px) {
  .modules-grid { grid-template-columns: repeat(2, 1fr); }
  .personas-grid { grid-template-columns: repeat(2, 1fr); }
  .pillars { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .hero-inner { grid-template-columns: 1fr; }
  .hero-mockup-wrap { display: none; }
  .problem-grid { grid-template-columns: 1fr; gap: 40px; }
  .pillars { grid-template-columns: 1fr; }
  .pricing-grid { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .modules-grid { grid-template-columns: 1fr; }
  .personas-grid { grid-template-columns: 1fr; }
}

/* HUMAN-IN-THE-LOOP / TRUST SECTION */
.hitl-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  margin-top: 48px;
}
.hitl-card {
  background: white;
  border-radius: 16px;
  padding: 32px;
  border: 1px solid var(--gray-100);
  transition: all 0.2s;
}
.hitl-card:hover { box-shadow: 0 8px 24px rgba(30,58,95,0.08); transform: translateY(-2px); }
.hitl-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 24px; margin-bottom: 20px;
}
.hitl-icon-1 { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); }
.hitl-icon-2 { background: rgba(74,144,217,0.1); border: 1px solid rgba(74,144,217,0.2); }
.hitl-icon-3 { background: rgba(139,92,246,0.1); border: 1px solid rgba(139,92,246,0.2); }
.hitl-card h3 { font-size: 12px; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; }
.hitl-card h4 { font-size: 19px; font-weight: 700; color: var(--primary); margin-bottom: 12px; }
.hitl-card p { font-size: 14px; color: var(--gray-500); line-height: 1.7; }
.hitl-card .hitl-quote {
  margin-top: 16px;
  padding: 12px 16px;
  background: var(--off-white);
  border-left: 3px solid var(--secondary);
  border-radius: 0 8px 8px 0;
  font-size: 13px; font-style: italic; color: var(--gray-700); line-height: 1.6;
}
.trust-strip {
  display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
  margin-top: 48px; padding-top: 36px;
  border-top: 1px solid var(--gray-100);
}
.trust-pill {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--off-white);
  border: 1px solid var(--gray-200);
  border-radius: 100px; padding: 10px 20px;
  font-size: 13px; font-weight: 600; color: var(--gray-700);
}
.trust-pill a { color: var(--secondary); text-decoration: none; font-weight: 700; }
.trust-pill a:hover { text-decoration: underline; }

.hero-trust-line {
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  font-size: 12px; color: var(--gray-500); margin-top: 14px;
}
.hero-trust-line span.ht-dot {
  display: inline-block; width: 4px; height: 4px;
  border-radius: 50%; background: var(--gray-300);
}

@media (max-width: 768px) {
  .hitl-grid { grid-template-columns: 1fr; }
  .trust-strip { gap: 8px; }
}
</style>

<BaseLayout title="Cadence — Management by Design, Not by Luck" description="The AI-powered operating plane that makes every manager your best manager. Structured 1:1s, goals, ER, recognition, and org intelligence in one platform.">

<!-- HERO -->
<section class="hero-light" id="hero">
  <div class="hero-inner">
    <div class="hero-content fade-up">
      <div class="hero-badge">Management Operating System</div>
      <h1 class="hero">Management by design, <em>not by luck.</em></h1>
      <p class="hero-sub">Structured 1:1s, goal tracking, ER, recognition, and org-health views — with AI summaries and coaching clearly labeled as preview. Talent calibration is a roadmap preview, not a current GA module.</p>
      <p class="hero-body">Remote and hybrid work removed the informal safety net. What replaced it is a lottery: some employees get a manager who coaches, advocates, and develops them. Most don't. Cadence gives every manager a consistent system — and AI that surfaces what they need to lead well. <strong>The tool does the scaffolding. Your managers do the leading.</strong></p>
      <div class="hero-ctas">
        <a href={withBase('/beta')} class="btn btn-primary btn-lg">Request beta access →</a>
        <a href={withBase('/product')} class="btn btn-secondary btn-lg">See the platform</a>
      </div>
      <div class="hero-trust-line">
        <span>AI surfaces signal</span>
        <span class="ht-dot"></span>
        <span>Managers make every call</span>
        <span class="ht-dot"></span>
        <span>Your data never trains AI models</span>
        <span class="ht-dot"></span>
        <a href={withBase('/security')}>Full trust &amp; privacy details →</a>
      </div>
      <div class="social-proof" style="margin-top:20px;">
        <div class="social-proof-avatars">
          <span class="av1">VP</span>
          <span class="av2">HR</span>
          <span class="av3">C</span>
          <span class="av4">L2</span>
        </div>
        <span>Trusted by People leaders at hybrid and remote-first organizations.</span>
      </div>
    </div>
    <div class="hero-mockup-wrap fade-up" style="transition-delay:0.15s">
      <div class="browser-chrome">
        <div class="chrome-dots">
          <span class="dot-red"></span>
          <span class="dot-yellow"></span>
          <span class="dot-green"></span>
        </div>
        <div class="chrome-bar">app.cadencehr.ai / workspace</div>
      </div>
      <div class="hero-mockup-frame">
        <img
          src={withBase('/screenshots/cadence-homepage-tile-2026-05-15.png')}
          alt="Cadence People Operating System — culture health score 83, 4 KPIs, and engagement trend"
          class="hero-mockup-shot"
          width="1400"
          height="800"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<!-- HUMAN-IN-THE-LOOP / TRUST -->
<section class="section section-light" id="how-it-works">
  <div class="container">
    <div class="center">
      <div class="section-badge">How Cadence Works</div>
      <h2 class="section-headline fade-up" style="max-width:680px;">AI develops managers. Managers develop people.</h2>
      <p class="section-subhead fade-up" style="max-width:640px;">Cadence is a management operating system — not a decision-maker. The AI helps managers prepare, reflect, and improve. Every people decision stays with the human who owns it.</p>
    </div>
    <div class="hitl-grid">
      <div class="hitl-card fade-up">
        <div class="hitl-icon hitl-icon-1">🧭</div>
        <h3>Human-in-the-loop</h3>
        <h4>AI coaches. You decide.</h4>
        <p>Cadence surfaces patterns — low 1:1 frequency, recognition activity, goal drift, ER context, and survey signals. Your managers review every suggestion, edit every agenda item, and make every call. The AI never takes an action on a person that isn't human-approved first.</p>
        <div class="hitl-quote">"The tool does the preparation. The manager does the leading."</div>
      </div>
      <div class="hitl-card fade-up" style="transition-delay:0.1s">
        <div class="hitl-icon hitl-icon-2">🔒</div>
        <h3>Data &amp; Privacy</h3>
        <h4>Your conversations stay yours.</h4>
        <p>What's said in a 1:1 stays governed by tenant access controls and consent policy. AI-generated summaries are a preview workflow, and HR-facing views should rely on aggregate signals rather than raw meeting transcripts. Your workforce data never trains any AI model, ours or anyone else's.</p>
        <div class="hitl-quote">Audio capture is optional. The platform delivers full value with text-only structured notes.</div>
      </div>
      <div class="hitl-card fade-up" style="transition-delay:0.2s">
        <div class="hitl-icon hitl-icon-3">📋</div>
        <h3>Documentation</h3>
        <h4>The record your counsel will appreciate.</h4>
        <p>Consistent, timestamped 1:1 notes, goal updates, and ER case documentation built into every interaction — not added retroactively. When you need a defensible performance record, it's already there, structured and complete, from the first conversation.</p>
        <div class="hitl-quote">Built for the scenario where a manager and an employee disagree about what was said.</div>
      </div>
    </div>
    <div class="trust-strip fade-up">
      <div class="trust-pill"><span>🔒</span> Data encrypted at rest &amp; in transit</div>
      <div class="trust-pill"><span>👤</span> No AI decisions on people</div>
      <div class="trust-pill"><span>🚫</span> Your data never trains AI models</div>
      <div class="trust-pill"><span>📄</span> DPA available on request</div>
      <div class="trust-pill"><span>✅</span> SOC 2 readiness in progress</div>
      <div class="trust-pill"><span>🔍</span> <a href={withBase('/security')}>Full trust &amp; compliance details →</a></div>
    </div>
  </div>
</section>

<!-- PROBLEM -->
<section class="section-problem" id="problem">
  <div class="container">
    <div class="section-tag" style="color:rgba(255,255,255,0.5)">The Problem</div>
    <h2 class="section-headline white fade-up" style="max-width:560px;">The management problem hiding in plain sight.</h2>
    <div class="problem-grid">
      <div class="problem-text fade-up">
        <p>When your team is distributed, the informal mechanisms that made management work disappear. No hallway conversations. No reading body language. No overhearing who's struggling or celebrating who's winning in the break room.</p>
        <p>What you have instead: a stack of disconnected tools, compliance theater, and a manager population whose effectiveness varies wildly — and whose impact on retention you can't measure until someone resigns.</p>
      </div>
      <div class="failure-cards fade-up" style="transition-delay:0.1s">
        <div class="failure-card">
          <div class="failure-icon">🔗</div>
          <h4>The Fragmented Stack</h4>
          <p>One tool for 1:1s. Another for performance. Another for surveys. Another for recognition. Six platforms that don't talk to each other — and nobody has the full picture.</p>
        </div>
        <div class="failure-card">
          <div class="failure-icon">🗃️</div>
          <h4>The HRIS Gap</h4>
