---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';
---

<BaseLayout
  title="Page not found | Cadence"
  description="The page you requested does not exist."
  canonicalPath="/404"
>
  <main class="not-found">
    <p class="not-found__eyebrow">404</p>
    <h1>Page not found</h1>
    <p>The page you requested does not exist or is no longer available.</p>
    <a href={withBase('/')} class="not-found__link">Return to Cadence</a>
  </main>
</BaseLayout>

<style>
  .not-found {
    max-width: 720px;
    margin: 0 auto;
    padding: 112px 24px;
    text-align: center;
  }

  .not-found__eyebrow {
    color: var(--secondary);
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
  }

  h1 {
    color: var(--primary);
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.1;
    margin: 0 0 16px;
  }

  p {
    color: var(--gray-700);
    font-size: 18px;
    line-height: 1.6;
    margin: 0 auto 28px;
  }

  .not-found__link {
    background: var(--primary);
    border-radius: 8px;
    color: white;
    display: inline-block;
    font-weight: 700;
    padding: 12px 18px;
    text-decoration: none;
  }
</style>
