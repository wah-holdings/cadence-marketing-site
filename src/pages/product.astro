---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';
---
<style>
.module-nav {
  background: var(--white);
  border-bottom: 1px solid var(--gray-100);
  position: sticky;
  top: 64px;
  z-index: 90;
  overflow-x: auto;
}
.module-nav-inner {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  gap: 4px;
  height: 48px;
  align-items: center;
  white-space: nowrap;
}
.module-nav-inner a {
  font-size: 13px;
  font-weight: 500;
  color: var(--gray-500);
  text-decoration: none;
  padding: 6px 12px;
  border-radius: 6px;
  transition: background 0.15s, color 0.15s;
  flex-shrink: 0;
}
.module-nav-inner a:hover { background: var(--gray-50); color: var(--primary); }
.mock-panel {
  background: var(--gray-50);
  border-radius: 16px;
  border: 1px solid var(--gray-100);
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(30,58,95,0.08);
  padding: 24px;
  min-height: 280px;
}
.mock-dark {
  background: #0a1628;
  border-radius: 12px;
  padding: 20px;
}
.mock-title { font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 14px; }
.mock-row {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 8px;
  padding: 12px 14px;
  margin-bottom: 8px;
}
.mock-row-title { font-size: 12px; font-weight: 600; color: white; margin-bottom: 4px; }
.mock-row-sub { font-size: 11px; color: rgba(255,255,255,0.4); }
.mock-badge {
  display: inline-flex; align-items: center;
  padding: 2px 8px; border-radius: 4px;
  font-size: 10px; font-weight: 600;
}
.badge-green { background: rgba(16,185,129,0.15); color: #10B981; }
.badge-blue { background: rgba(74,144,217,0.15); color: #6AAAE5; }
.badge-orange { background: rgba(245,166,35,0.15); color: #F5A623; }
.badge-red { background: rgba(239,68,68,0.15); color: #EF4444; }
.mock-kpi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 12px; }
.mock-kpi { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 8px; padding: 10px; }
.mock-kpi-label { font-size: 10px; color: rgba(255,255,255,0.35); margin-bottom: 5px; }
.mock-kpi-val { font-size: 18px; font-weight: 800; color: white; }
.prog-bar-bg { height: 5px; background: rgba(255,255,255,0.08); border-radius: 3px; margin-top: 6px; }
.prog-bar-fill { height: 5px; border-radius: 3px; }
.prog-green { background: #10B981; }
.prog-blue { background: #4A90D9; }
.prog-orange { background: #F5A623; }
.ai-coaching-box {
  background: rgba(245,166,35,0.08);
  border: 1px solid rgba(245,166,35,0.2);
  border-radius: 8px;
  padding: 12px 14px;
  margin-top: 10px;
}
.ai-coaching-label { font-size: 10px; font-weight: 700; color: var(--accent); margin-bottom: 7px; text-transform: uppercase; letter-spacing: 0.06em; }
.ai-coaching-item { font-size: 11px; color: rgba(255,255,255,0.6); margin-bottom: 4px; display: flex; gap: 6px; }
.nine-box-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  gap: 4px;
  height: 180px;
}
.nine-box-cell {
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 600;
  color: rgba(255,255,255,0.6);
  position: relative;
}
.cell-ll { background: rgba(239,68,68,0.2); border: 1px solid rgba(239,68,68,0.3); }
.cell-lm { background: rgba(245,158,11,0.15); border: 1px solid rgba(245,158,11,0.2); }
.cell-lh { background: rgba(74,144,217,0.15); border: 1px solid rgba(74,144,217,0.2); }
.cell-ml { background: rgba(245,158,11,0.15); border: 1px solid rgba(245,158,11,0.2); }
.cell-mm { background: rgba(74,144,217,0.15); border: 1px solid rgba(74,144,217,0.2); }
.cell-mh { background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.2); }
.cell-hl { background: rgba(74,144,217,0.15); border: 1px solid rgba(74,144,217,0.2); }
.cell-hm { background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.2); }
.cell-hh { background: rgba(16,185,129,0.3); border: 1px solid rgba(16,185,129,0.4); }
.cell-dot { width: 10px; height: 10px; border-radius: 50%; background: white; opacity: 0.9; }
.module-section {
  padding: 80px 0;
  border-bottom: 1px solid var(--gray-100);
}
.module-section:last-child { border-bottom: none; }
.module-number-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 700;
  color: var(--secondary);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12px;
}
.product-shot-frame {
  border-radius: 16px;
  overflow: hidden;
}
.product-shot {
  width: 100%;
  aspect-ratio: 16 / 9;
  display: block;
  object-fit: cover;
  object-position: center;
}
@media (max-width: 768px) {
  .module-nav { top: 64px; }
  .mock-kpi-row { grid-template-columns: repeat(2, 1fr); }
}
</style>

<BaseLayout title="Product — Cadence Platform" description="One operating plane. Cadence connects 1:1s, goals, Personality Intelligence, ER, recognition, surveys, job architecture, and culture intelligence — with roadmap previews clearly labeled." activeNav="product">

<div class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href={withBase('/')}>Home</a><span>/</span>Product</div>
    <div class="section-badge" style="background:rgba(245,166,35,0.15);border:1px solid rgba(245,166,35,0.25);color:var(--accent-light);">Live Workflows + Roadmap Previews</div>
    <h1>People-management workflows — <span class="accent">clearly separated from roadmap.</span></h1>
    <p>Most organizations run management across five or six disconnected tools. Cadence is building one connected operating plane. Current live workflows and roadmap previews are labeled below.</p>
    <div class="btn-group" style="justify-content:center;">
      <a href="https://app.cadencehr.ai/signup?intent=self-serve&source=apex-product" class="btn btn-accent btn-lg">Start free trial</a>
      <a href="#one-on-ones" class="btn btn-white-outline btn-lg">Explore the modules ↓</a>
    </div>
  </div>
</div>

<div class="module-nav">
  <div class="module-nav-inner">
    <a href="#one-on-ones">💬 1:1 Engine</a>
    <a href="#goals">🎯 Goals</a>
    <a href="#personality-intelligence">🧩 Personality Intelligence</a>
    <a href="#nine-box">⬛ 9-Box</a>
    <a href="#connected-agents">🔌 Connected Agents</a>
    <a href="#er">📋 ER</a>
    <a href="#recognition">⭐ Recognition</a>
    <a href="#surveys">📊 Surveys</a>
    <a href="#job-architecture">🏗️ Job Architecture</a>
    <a href="#culture-scorecard">🏆 Culture Scorecard</a>
  </div>
</div>

<section class="module-section" id="one-on-ones">
  <div class="container">
    <div class="feature-block">
      <div>
        <div class="module-number-tag">Module 01 · 💬 1:1 Management Engine</div>
        <h2 class="section-headline">The heartbeat of Cadence.</h2>
        <p>Every functional management relationship runs through the 1:1. Cadence makes it structural — not aspirational. Structured agendas, follow-through, AI summaries, and private coaching lanes are live workflows.</p>
        <p>Most organizations run 1:1s inconsistently, document them nowhere, and lose every insight the moment the call ends. Cadence gives the conversation a durable workspace today, with AI support that develops managers and employees while humans stay accountable.</p>
        <ul class="feature-list">
          <li>Shared agenda builder — both parties contribute, nothing gets forgotten</li>
          <li>AI-generated meeting summaries with key decisions and action items</li>
          <li>Private post-meeting coaching for the manager</li>
          <li>Private post-meeting coaching for the employee</li>
          <li>Meeting health metrics: frequency, talk-time ratio, topic coverage</li>
          <li>Manager-employee relationship history — every 1:1, searchable, private</li>
        </ul>
      </div>
      <div class="mock-panel" style="padding:0;min-height:unset;">
        <img
          src={withBase('/screenshots/cadence-1on1-tile-2026-05-15.png')}
          alt="Cadence 1:1 Engine — AI coaching insights panel with risk flags, coaching notes, and goal updates"
          class="product-shot-frame product-shot"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<section class="module-section" id="goals" style="background:var(--gray-50);">
  <div class="container">
    <div class="feature-block reverse">
      <div>
        <div class="module-number-tag">Module 02 · 🎯 Goals &amp; OKR Tracking</div>
        <h2 class="section-headline">Accountability built into the conversation.</h2>
        <p>Goals that live in a separate system are goals that get reviewed once a quarter. Cadence supports goal creation, updates, and progress tracking today; goal context inside the 1:1 remains preview until current tenant proof is attached.</p>
        <p>Set goals at every level, track progress, and keep accountability close to the management rhythm. AI recommendations remain preview rather than a current GA promise.</p>
        <ul class="feature-list">
          <li>Company, team, and individual goal cascading</li>
          <li>OKR framework with weighted key results</li>
          <li>Preview: progress visible in the 1:1 sidebar</li>
          <li>Goal progress tracking over time</li>
          <li>Preview: AI-generated goal health recommendations</li>
          <li>Roadmap: review-cycle integration</li>
        </ul>
      </div>
      <div class="mock-panel" style="padding:0;min-height:unset;">
        <img
          src={withBase('/screenshots/cadence-goals-tile-2026-05-15.png')}
          alt="Cadence Goals &amp; OKRs — 3 goal bars with On Track, At Risk, Behind status and live % readouts"
          class="product-shot-frame product-shot"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<section class="module-section" id="personality-intelligence">
  <div class="container">
    <div class="feature-block">
      <div>
        <div class="module-number-tag">Module 03 · 🧩 Personality Intelligence</div>
        <h2 class="section-headline">How your people work, made useful without becoming a score.</h2>
        <p>Cadence names this Personality Intelligence because the product is not a standalone form. The foundation is live in the Professional tier: a consented instrument, a derived working-style profile, a team view, and a coaching read-surface that helps people understand collaboration patterns.</p>
        <p>Roadmap direction: that working-style signal becomes connective intelligence across 1:1s, coaching moments, and talent conversations. Those woven claims stay labeled as coming until each integration ships in production.</p>
        <ul class="feature-list">
          <li>Live: consented instrument and derived working-style profile</li>
          <li>Live: team working-style view for collaboration context</li>
          <li>Live: coaching read-surface for conversation prep</li>
          <li>Coming: 1:1 prompts informed by working-style fit</li>
          <li>Coming: coaching moments that reflect dyad fit without exposing raw responses</li>
          <li>Hard line: personality signal never feeds scoring, ratings, 9-box placement, or compensation</li>
        </ul>
      </div>
      <div class="mock-panel">
        <div class="mock-dark">
          <div class="mock-title">Personality Intelligence · Working-style profile</div>
          <div class="mock-row">
            <div class="mock-row-title">Collaboration profile</div>
            <div class="mock-row-sub">Prefers written context before high-stakes discussion</div>
          </div>
          <div class="mock-row">
            <div class="mock-row-title">Dyad fit read-surface</div>
            <div class="mock-row-sub">Manager and direct report have different feedback-tempo preferences</div>
          </div>
          <div class="ai-coaching-box">
            <div class="ai-coaching-label">Coming connective use</div>
            <div class="ai-coaching-item">• 1:1 prep can adapt to working-style fit once shipped</div>
            <div class="ai-coaching-item">• Raw OCEAN responses never cross the module boundary</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="module-section" id="nine-box">
  <div class="container">
    <div class="feature-block">
      <div>
        <div class="module-number-tag">Live · ⬛ 9-Box Talent Calibration</div>
        <h2 class="section-headline">Calibration you can actually run today.</h2>
        <p>Core 9-box calibration is live in current purchasable access: blind dual-rating, L1/L2 divergence review, and structured calibration follow-through. Personality Intelligence is explicitly conversation support, not a scoring input.</p>
        <p>Roadmap direction: KVD nominations, predictive retention, and advanced movement analysis stay roadmap-labeled until each ships in production.</p>
        <ul class="feature-list">
          <li>Live: blind dual-rating for L1 and L2 inputs</li>
          <li>Live: divergence review and calibration prompts</li>
          <li>Live: structured follow-through for calibration outcomes</li>
          <li>Included in Professional and Enterprise tiers · KVD and predictive retention remain roadmap</li>
        </ul>
      </div>
      <div class="mock-panel" style="padding:0;min-height:unset;">
        <img
          src={withBase('/screenshots/cadence-9box-tile-2026-05-15.png')}
          alt="Cadence 9-Box talent calibration — 3x3 grid with name pills, category labels, and performance axis"
          class="product-shot-frame product-shot"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<section class="module-section" id="er" style="background:var(--gray-50);">
  <div class="container">
    <div class="feature-block reverse">
      <div>
        <div class="module-number-tag">Module 04 · 📋 ER Command Center</div>
        <h2 class="section-headline">ER cases are expensive. Cadence reduces how many open.</h2>
        <p>Most ER tools manage cases after they surface. Cadence connects ER case management to the broader management record; AI coaching, recognition-ratio enforcement, and declining-pattern prediction remain preview or roadmap until verified as GA.</p>
        <p>When a case does open, it opens with full context: every 1:1 note, every recognition interaction, every goal conversation, every prior HR touchpoint. Nothing starts cold.</p>
        <ul class="feature-list">
          <li>Full case lifecycle: verbal warning → written → PIP → separation</li>
          <li>Case history connected to the full management record</li>
          <li>Live role-based access separates workspace admin, manager, and employee views; deeper HR, executive, and auditor policy surfaces remain entitlement-scoped</li>
          <li>PIP builder with structured check-in cadence and measurable milestones</li>
          <li>Preview: pattern-history analysis for employees or managers</li>
          <li>Preview: manager problem-solver score as an upstream prevention metric</li>
        </ul>
      </div>
      <div class="mock-panel" style="padding:0;min-height:unset;">
        <img
          src={withBase('/screenshots/cadence-er-tile-2026-05-15-v2.png')}
          alt="Cadence ER Command Center — active case card with lifecycle stages and severity badge"
          class="product-shot-frame product-shot"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<section class="module-section" id="recognition">
  <div class="container">
    <div class="feature-block">
      <div>
        <div class="module-number-tag">Module 05 · ⭐ Recognition</div>
        <h2 class="section-headline">Recognition as accountability, not wallpaper.</h2>
        <p>Recognition platforms often become noise — a feed of "congrats" posts that nobody reads and management ignores. Cadence treats recognition as an operational metric with real teeth.</p>
        <p>Recognition feed and posting are live. Recognition-ratio analysis is a preview insight, not an enforced GA control.</p>
        <ul class="feature-list">
          <li>Preview: 5:1 Rule tracking per manager</li>
          <li>Preview: L2 visibility into recognition ratios</li>
          <li>Peer, manager, and cross-functional recognition channels</li>
          <li>Values tagging — connect recognition to company values</li>
          <li>Preview: recognition-gap insights</li>
          <li>Roadmap: reward integration hooks (points, gift cards, experiences)</li>
        </ul>
      </div>
      <div class="mock-panel" style="padding:0;min-height:unset;">
        <img
          src={withBase('/screenshots/cadence-recognition-tile-2026-05-15.png')}
          alt="Cadence Recognition — 3 stacked recognition cards with value badges and 6.2:1 manager ratio"
          class="product-shot-frame product-shot"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<section class="module-section" id="surveys" style="background:var(--gray-50);">
  <div class="container">
    <div class="feature-block reverse">
      <div>
        <div class="module-number-tag">Module 06 · 📊 Survey Engine</div>
        <h2 class="section-headline">Survey data that connects to a manager, not just a department.</h2>
        <p>Most survey tools produce beautiful company-level dashboards that tell you something is wrong but not where or why. Cadence supports tokenized pulse responses and aggregate survey analytics today; full campaign management and manager-level attribution remain preview or roadmap.</p>
        <ul class="feature-list">
          <li>Live: tokenized pulse-survey response collection</li>
          <li>Preview: manager-level signal attribution</li>
          <li>Preview: AI-generated comment summaries</li>
          <li>Preview: cross-signal correlation across survey, 1:1, and recognition data</li>
          <li>Anonymous response guarantees with minimum cohort sizes</li>
          <li>Roadmap: manager action planning from survey results</li>
        </ul>
      </div>
      <div class="mock-panel" style="padding:0;min-height:unset;">
        <img
          src={withBase('/screenshots/cadence-surveys-tile-2026-05-15.png')}
          alt="Cadence Survey Engine — eNPS +42 score with 12-month trend, dimension heatmap, and top manager"
          class="product-shot-frame product-shot"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<section class="module-section" id="job-architecture">
  <div class="container">
    <div class="feature-block">
      <div>
        <div class="module-number-tag">Module 07 · 🏗️ Job Architecture</div>
        <h2 class="section-headline">Role context, honestly scoped.</h2>
        <p>Nothing breaks trust faster than an employee who doesn't know what's expected at their level — or what they'd need to do to grow. Cadence supports Job Architecture import, versioned role definitions, level context, and role assignments today.</p>
        <ul class="feature-list">
          <li>Job architecture data import for admin setup</li>
          <li>Versioned role definitions</li>
          <li>Level context and role assignment</li>
          <li>Roadmap: career path mapping</li>
          <li>Roadmap preview: calibration-informed role-fit workflows</li>
          <li>Roadmap: compensation banding integration</li>
        </ul>
      </div>
      <div class="mock-panel" style="padding:0;min-height:unset;">
        <img
          src={withBase('/screenshots/cadence-jobarch-tile-2026-05-15-v2.png')}
          alt="Cadence Job Architecture — L1-L4 ladder with current level highlighted and L4 ready badge"
          class="product-shot-frame product-shot"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<section class="module-section" id="culture-scorecard" style="background:var(--primary);">
  <div class="container">
    <div class="feature-block" style="border-bottom:none;">
      <div>
        <div class="module-number-tag" style="color:rgba(245,166,35,0.9);">Module 08 · 🏆 Culture Scorecard</div>
        <h2 class="section-headline white">The intelligence no fragmented stack can produce.</h2>
        <p style="color:rgba(255,255,255,0.75);font-size:16px;line-height:1.75;margin-bottom:16px;">Cadence connects 1:1 quality, ER patterns, recognition ratios, survey sentiment, and goal attainment into one management view. Working-style fit, calibration movement, and predictive risk are roadmap inputs, not current GA claims.</p>
        <ul class="feature-list" style="color:rgba(255,255,255,0.75);">
          <li>Manager scorecard and org-health heatmap</li>
          <li>Roadmap preview: predictive retention risk</li>
          <li>Heat maps: visual org health across locations, teams, levels</li>
          <li>Roadmap preview: high-performer environment scoring</li>
          <li>Preview: board-ready culture reporting</li>
          <li>Trend lines: org health over time, not just snapshots</li>
        </ul>
      </div>
      <div class="mock-panel" style="padding:0;min-height:unset;background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.12);">
        <img
          src={withBase('/screenshots/cadence-culture-tile-2026-05-15.png')}
          alt="Cadence Culture Scorecard — composite score 83 with 4 KPIs and dimension x department heatmap"
          class="product-shot-frame product-shot"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<section class="module-section" id="connected-agents">
  <div class="container">
    <div class="feature-block">
      <div>
        <div class="module-number-tag">Live · 🔌 Connected Agents (BYOA)</div>
        <h2 class="section-headline">Bring your own AI. Keep your audit trail.</h2>
        <p>Connect the AI assistants your team already uses to your Cadence workspace over the open Model Context Protocol (MCP). Your people query their own goals, 1:1 history, and recognition context from the tools they work in — under your tenant's permissions.</p>
        <p>Every connected-agent request is logged in the MCP audit trail, so admins see exactly which agent touched what data, when, on whose behalf. Included in Professional and Enterprise tiers.</p>
        <ul class="feature-list">
          <li>Bring-your-own-agent access over the open MCP standard</li>
          <li>Tenant-scoped permissions — agents see only what the connecting user can see</li>
          <li>MCP audit log for every connected-agent request</li>
          <li>Admin controls to enable, review, and revoke connected agents</li>
        </ul>
      </div>
      <div class="mock-panel">
        <div class="mock-dark">
          <div class="mock-title">Connected Agents · MCP audit log</div>
          <div class="mock-row">
            <div class="mock-row-title">Agent connected</div>
            <div class="mock-row-sub">Personal assistant authorized via workspace sign-in</div>
          </div>
          <div class="mock-row">
            <div class="mock-row-title">Request logged</div>
            <div class="mock-row-sub">read:goals — scoped to the connecting user's own records</div>
          </div>
          <div class="ai-coaching-box">
            <div class="ai-coaching-label">Admin visibility</div>
            <div class="ai-coaching-item">• Full audit trail of agent, user, scope, and timestamp</div>
            <div class="ai-coaching-item">• Revoke any connected agent at any time</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-cta">
  <div class="container">
    <h2>See it for yourself.</h2>
    <p>Start a trial workspace or compare the live workflows and roadmap-labeled modules before you bring Cadence to your team.</p>
    <div class="btn-group" style="justify-content:center;">
      <a href="https://app.cadencehr.ai/signup?intent=self-serve&source=apex-product-cta" class="btn btn-white btn-lg">Start free trial</a>
      <a href={withBase('/pricing')} class="btn btn-white-outline btn-lg">View pricing</a>
    </div>
  </div>
</section>

</BaseLayout>
