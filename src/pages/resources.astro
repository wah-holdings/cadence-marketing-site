<!-- WHY CADENCE -->
<section class="section section-white" id="why-cadence">
  <div class="container">
    <div class="center" style="margin-bottom:48px;">
      <div class="section-badge">Buyer's Guide</div>
      <h2 class="section-headline">Where each tool is genuinely best.</h2>
      <p class="section-subhead">We're not going to tell you every competitor is bad. They're not. Here's an honest read of where each wins — and when Cadence is the right call.</p>
    </div>
    <div class="grid-3">
      <div class="competitor-card">
        <div class="competitor-name">Lattice</div>
