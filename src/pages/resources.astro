---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';
import { g1PricingHref } from '../lib/g1CampaignLinks';
---
<style>
.resource-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 48px;
}
.resource-card {
  background: white;
  border-radius: 16px;
  padding: 28px;
  border: 1px solid var(--gray-100);
  text-decoration: none;
  display: block;
  transition: all 0.2s;
}
.resource-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(30,58,95,0.1); border-color: var(--gray-200); }
.resource-type {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--secondary);
  margin-bottom: 12px;
}
.resource-card h3 { font-size: 18px; font-weight: 700; color: var(--primary); line-height: 1.3; margin-bottom: 10px; }
.resource-card p { font-size: 14px; color: var(--gray-500); line-height: 1.6; margin-bottom: 16px; }
.resource-cta { font-size: 13px; font-weight: 600; color: var(--secondary); }
.resource-card--article { padding: 22px; }
.resource-card--article h3 { font-size: 16px; }

.manifesto-text {
  max-width: 760px;
  margin: 0 auto;
}
.manifesto-text p {
  font-size: 18px;
  color: var(--gray-700);
  line-height: 1.8;
  margin-bottom: 24px;
}
.manifesto-text h3 {
  font-size: 22px;
  font-weight: 800;
  color: var(--primary);
  line-height: 1.25;
  letter-spacing: -0.02em;
  margin: 32px 0 14px;
}
.manifesto-pull {
  border-left: 4px solid var(--accent);
  padding: 20px 24px;
  background: rgba(245,166,35,0.04);
  border-radius: 0 12px 12px 0;
  margin: 32px 0;
}
.manifesto-pull p {
  font-size: 22px;
  font-style: italic;
  color: var(--primary);
  line-height: 1.5;
  margin: 0;
  font-weight: 600;
}

.vs-table-wrap {
  overflow-x: auto;
  margin-top: 40px;
  border-radius: 14px;
  border: 1px solid var(--gray-100);
  box-shadow: 0 1px 3px rgba(30,58,95,0.04);
}
.vs-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 800px;
}
.vs-table th {
  background: var(--primary);
  color: white;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 14px 16px;
  text-align: center;
  white-space: nowrap;
}
.vs-table th:first-child { text-align: left; }
.vs-table th.cadence-col { background: var(--secondary); }
.vs-table td {
  padding: 12px 16px;
  font-size: 13px;
  text-align: center;
  border-bottom: 1px solid var(--gray-100);
  color: var(--gray-700);
}
.vs-table td:first-child { text-align: left; font-weight: 500; }
.vs-table tr:hover td { background: var(--gray-50); }
.vs-table tr:last-child td { border-bottom: none; }
.vs-yes { color: var(--success); font-size: 16px; font-weight: 700; }
.vs-no { color: var(--gray-300); font-size: 16px; }
.vs-partial { color: var(--warning); font-size: 13px; font-weight: 600; }
.group-row td { background: rgba(74,144,217,0.04); font-size: 11px; font-weight: 700; color: var(--secondary); text-transform: uppercase; letter-spacing: 0.08em; padding: 8px 16px; }

.win-card {
  background: white;
  border-radius: 14px;
  padding: 24px;
  border: 1px solid var(--gray-100);
  border-left: 4px solid var(--secondary);
  margin-bottom: 16px;
}
.win-card h4 { font-size: 15px; font-weight: 700; color: var(--primary); margin-bottom: 8px; }
.win-card p { font-size: 14px; color: var(--gray-500); line-height: 1.65; }

.competitor-card {
  background: white;
  border-radius: 14px;
  padding: 24px;
  border: 1px solid var(--gray-100);
}
.competitor-name { font-size: 16px; font-weight: 700; color: var(--primary); margin-bottom: 4px; }
.competitor-niche { font-size: 12px; color: var(--secondary); font-weight: 600; margin-bottom: 10px; }
.competitor-card p { font-size: 13px; color: var(--gray-500); line-height: 1.6; }

@media (max-width: 768px) {
  .resource-grid { grid-template-columns: 1fr; }
}
</style>

<BaseLayout title="Resources — Cadence Manifesto, Competitive Research, and Insights" description="The Cadence management manifesto, competitive teardown vs. 15Five/Lattice/Culture Amp, and the case for why management by design beats management by luck." activeNav="resources">

