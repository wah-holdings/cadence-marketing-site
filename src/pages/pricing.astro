---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';
import { g1SignupHref } from '../lib/g1CampaignLinks';

const pricingFaqItems = [
  {
    question: 'How does pricing work?',
    answer: 'Essentials and Professional start through self-serve signup. Enterprise is sales-led because larger deployments typically require security review, procurement, SSO planning, and custom rollout support.',
  },
  {
    question: "What's the minimum seat count?",
    answer: "Essentials starts at 50 seats. Professional starts at 100 seats. Enterprise is custom. If you're below the minimums, reach out anyway.",
  },
  {
    question: 'Is there an annual commitment required?',
    answer: 'The published pricing is for annual billing. Monthly billing is available at a 20% premium. Multi-year agreements receive additional discounts.',
  },
  {
    question: 'What tools does Cadence replace?',
    answer: 'Cadence Essentials targets 1:1 management, AI meeting summaries, manager-lane AI coaching, goals, recognition, pulse-survey response collection, and Job Architecture workflows. Professional adds ER case management, manager scorecard and org-health heatmap views, employee-lane AI coaching, 9-box calibration, Connected Agents (bring-your-own-AI over MCP with audit logging), and Personality working-style profiles. Enterprise adds OIDC and SAML SSO plus configurable retention. Turnover prediction, full survey campaign management, personality signal woven into 1:1s, SCIM provisioning, and role-recasting workflows remain preview, planning, or roadmap items.',
  },
  {
    question: 'Do you offer a free trial?',
    answer: 'Yes. Essentials starts with a free trial through the live signup funnel. Professional checkout starts from the same signup path.',
  },
  {
    question: 'Is Cadence making people decisions with AI?',
    answer: 'No. Cadence uses AI to surface patterns, summarize work, suggest coaching prompts, and route issues for human review. It does not make employment decisions. Discipline, promotion, termination, compensation, performance ratings, and formal ER actions require accountable human judgment and normal company process.',
  },
  {
    question: 'What happens to 1:1 notes and meeting data?',
    answer: '1:1 notes, transcripts, summaries, coaching outputs, goals, recognition, survey signals, ER records, and scorecard telemetry are used to deliver Cadence to your company. They are not used to train, fine-tune, or improve Cadence AI models by default, unless your company explicitly agrees in writing.',
  },
  {
    question: 'Does audio recording start automatically?',
    answer: 'No. Audio capture is optional and consent-gated. Cadence is useful with or without audio: the operating plane still supports agendas, action items, goals, recognition, surveys, ER workflows, and scorecard signals.',
  },
  {
    question: 'Can we buy self-serve before a full security review?',
    answer: 'Essentials and Professional are built for teams that can start from standard terms and standard controls. If your purchase requires security review, procurement, SSO/SAML, custom legal terms, regulated privacy review, custom privacy deployment, or more than 300 seats, Cadence routes you to Enterprise before checkout.',
  },
  {
    question: 'Is a DPA available?',
    answer: 'Yes, a DPA review path is part of the buying motion. If your deployment requires a DPA before employee personal data is processed, use the Enterprise/legal review path before activating covered features.',
  },
  {
    question: 'How does Cadence use manager taxonomy?',
    answer: 'Cadence looks for management behavior patterns across operational signals such as 1:1 cadence, follow-through, recognition, goals, ER outcomes, and eligible aggregate survey signals. Taxonomy outputs are decision-support for trained human review. They are not automated employment decisions.',
  },
  {
    question: 'Are survey comments attached to managers?',
    answer: "No. Open-text survey themes are used only after Cadence's anonymity and de-identification thresholds are met. Raw open text is not surfaced in manager taxonomy review packets.",
  },
];

const pricingFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pricingFaqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---
<style>
.pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; align-items: start; }
.pricing-card { background: var(--white); border-radius: 18px; border: 1.5px solid var(--gray-200); padding: 36px 32px; position: relative; transition: all 0.2s; display: flex; flex-direction: column; }
.pricing-card:hover { box-shadow: 0 12px 40px rgba(30,58,95,0.1); transform: translateY(-2px); }
.pricing-card.featured { border-color: var(--secondary); box-shadow: 0 0 0 4px rgba(74,144,217,0.1), 0 20px 48px rgba(74,144,217,0.1); }
.pricing-badge-pill { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); padding: 5px 18px; background: var(--accent); color: white; border-radius: 20px; font-size: 11px; font-weight: 700; white-space: nowrap; letter-spacing: 0.05em; }
.pricing-tier-name { font-size: 13px; font-weight: 700; color: var(--secondary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }
.pricing-tagline { font-size: 14px; color: var(--gray-500); margin-bottom: 24px; line-height: 1.5; }
.price-big { font-size: 48px; font-weight: 900; color: var(--primary); letter-spacing: -0.04em; line-height: 1; margin-bottom: 6px; }
.price-big sup { font-size: 24px; vertical-align: super; font-weight: 700; letter-spacing: 0; }
.price-period { font-size: 14px; color: var(--gray-500); margin-bottom: 6px; }
.price-custom { font-size: 36px; font-weight: 900; color: var(--primary); line-height: 1; margin-bottom: 6px; }
.best-for { font-size: 12px; color: var(--gray-500); background: var(--gray-50); padding: 8px 12px; border-radius: 8px; margin: 16px 0 24px; line-height: 1.5; }
.best-for strong { color: var(--primary); }
.pricing-cta-btn { display: block; text-align: center; padding: 13px 24px; border-radius: 10px; font-size: 15px; font-weight: 700; text-decoration: none; transition: all 0.15s; margin-bottom: 28px; }
.cta-secondary-btn { background: var(--secondary); color: white; }
.cta-secondary-btn:hover { background: var(--secondary-dark); }
.cta-outline-btn { background: transparent; color: var(--primary); border: 1.5px solid var(--gray-200); }
.cta-outline-btn:hover { border-color: var(--primary); }
.pricing-divider { height: 1px; background: var(--gray-100); margin-bottom: 24px; }
.includes-label { font-size: 11px; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 14px; }
.features-list { list-style: none; display: flex; flex-direction: column; gap: 11px; flex: 1; }
.features-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: var(--gray-700); line-height: 1.45; }
.check-y { flex-shrink: 0; width: 16px; height: 16px; border-radius: 50%; background: rgba(74,144,217,0.1); display: flex; align-items: center; justify-content: center; margin-top: 1px; font-size: 9px; font-weight: 800; color: var(--secondary); }
.check-y::after { content: '✓'; }
.savings-row { display: flex; align-items: center; justify-content: space-between; gap: 20px; background: var(--gray-50); border-radius: 12px; padding: 20px 28px; border: 1px solid var(--gray-100); margin-top: 32px; flex-wrap: wrap; }
.savings-text { font-size: 14px; color: var(--gray-700); line-height: 1.6; }
.savings-text strong { color: var(--primary); }
.savings-text .strikethrough { text-decoration: line-through; color: var(--gray-500); }
.savings-text .highlight { color: var(--success); font-weight: 700; }
.savings-link { font-size: 14px; font-weight: 600; color: var(--secondary); text-decoration: none; white-space: nowrap; }
.compare-wrap { margin-top: 64px; background: white; border-radius: 16px; border: 1.5px solid var(--gray-100); overflow: hidden; }
.compare-head { display: grid; grid-template-columns: 2.5fr 1fr 1fr 1fr; background: var(--primary); color: white; padding: 18px 24px; font-size: 13px; font-weight: 700; text-align: center; }
.compare-head .feature-col { text-align: left; color: white; font-weight: 600; font-size: 12px; }
.compare-group { grid-column: 1 / -1; padding: 10px 24px; font-size: 11px; font-weight: 700; color: var(--secondary); background: rgba(74,144,217,0.04); text-transform: uppercase; letter-spacing: 0.08em; border-top: 1px solid var(--gray-100); }
.compare-row { display: grid; grid-template-columns: 2.5fr 1fr 1fr 1fr; padding: 12px 24px; border-top: 1px solid var(--gray-100); align-items: center; font-size: 13px; text-align: center; background: white; }
.compare-row > div { background: white; }
.compare-row > .compare-group { background: rgba(74,144,217,0.04); }
.compare-row:hover { background: var(--gray-50); }
.compare-feature-name { text-align: left; color: var(--gray-700); }
.compare-yes { color: var(--gray-900); font-size: 16px; font-weight: 800; }
.compare-no { color: var(--gray-900); font-size: 16px; font-weight: 700; }
.compare-partial { color: var(--gray-900); font-size: 13px; font-weight: 800; }
.roadmap-li { color: var(--gray-500); }
.roadmap-li::before { content: 'Coming'; flex-shrink: 0; margin-top: 1px; padding: 2px 6px; border-radius: 999px; background: rgba(180,83,9,0.12); color: var(--accent); font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; }
.trust-section { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 24px; align-items: stretch; margin-top: 40px; }
.trust-panel,
.checkout-panel,
.enterprise-route-panel {
  background: var(--white);
  border: 1px solid var(--gray-100);
  border-radius: 14px;
  padding: 26px;
}
.trust-panel h3,
.checkout-panel h3,
.enterprise-route-panel h3 { font-size: 20px; color: var(--primary); margin-bottom: 18px; }
.trust-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.trust-card { background: var(--gray-50); border: 1px solid var(--gray-100); border-radius: 12px; padding: 18px; }
.trust-card strong { display: block; color: var(--primary); font-size: 14px; margin-bottom: 8px; }
.trust-card p { color: var(--gray-600); font-size: 13px; line-height: 1.55; }
.trust-compact { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; }
.trust-compact span { background: rgba(74,144,217,0.08); border: 1px solid rgba(74,144,217,0.18); border-radius: 999px; color: var(--primary); font-size: 12px; font-weight: 700; padding: 7px 10px; }
.checkout-panel { display: flex; flex-direction: column; justify-content: space-between; }
.checkout-panel p { color: var(--gray-600); font-size: 14px; line-height: 1.65; margin-bottom: 14px; }
.checkout-note { background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.18); border-radius: 10px; padding: 14px; color: var(--primary); font-size: 13px; line-height: 1.55; }
.enterprise-route-panel { margin-top: 32px; display: grid; grid-template-columns: 1fr auto; gap: 20px; align-items: center; background: var(--primary); border-color: var(--primary); }
.enterprise-route-panel h3 { color: var(--white); margin-bottom: 8px; }
.enterprise-route-panel p { color: rgba(255,255,255,0.92); font-size: 14px; line-height: 1.65; max-width: 740px; }
.faq-list { display: flex; flex-direction: column; gap: 20px; margin-top: 40px; }
.faq-item { background: white; border-radius: 12px; border: 1px solid var(--gray-100); padding: 24px; }
.faq-q { font-size: 16px; font-weight: 700; color: var(--primary); margin-bottom: 10px; }
.faq-a { font-size: 15px; color: var(--gray-700); line-height: 1.7; }
.signup-notice { background: rgba(74,144,217,0.08); border: 1px solid rgba(74,144,217,0.2); border-radius: 12px; padding: 20px 24px; margin-top: 40px; display: flex; gap: 14px; align-items: flex-start; }
.signup-notice-icon { font-size: 20px; flex-shrink: 0; color: var(--gray-900); background: white; border-radius: 999px; }
.signup-notice-text { font-size: 14px; color: var(--gray-700); line-height: 1.65; }
.signup-notice-text strong { color: var(--primary); }
.page-hero,
.page-hero h1,
.page-hero h1 .accent,
.page-hero p,
.page-hero .breadcrumb,
.page-hero .breadcrumb a {
  color: white;
}
.page-hero .section-badge {
  background: var(--primary-dark) !important;
  border-color: rgba(255,255,255,0.85) !important;
  color: white !important;
}
.page-hero::before { display: none; }
.signup-notice-icon {
  background: #064E3B;
  color: white;
  width: 28px;
  height: 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
@media (max-width: 768px) {
  .pricing-grid { grid-template-columns: 1fr; }
  .trust-section,
  .enterprise-route-panel { grid-template-columns: 1fr; }
  .trust-grid { grid-template-columns: 1fr; }
  .compare-head { grid-template-columns: 1.5fr 1fr 1fr; }
  .compare-row { grid-template-columns: 1.5fr 1fr 1fr; }
  .compare-row > *:last-child { display: none; }
  .compare-head > *:last-child { display: none; }
}
</style>

<BaseLayout title="Pricing — Cadence: Transparent Pricing" description="Cadence pricing, current access, and roadmap-labeled feature comparison including Personality Intelligence." activeNav="pricing" structuredData={pricingFaqSchema}>

<div class="page-hero" style="background:#1E3A5F;color:#FFFFFF;">
  <div class="container">
    <div class="breadcrumb" style="color:#FFFFFF;"><a href={withBase('/')} style="color:#FFFFFF;text-decoration:underline;text-underline-offset:3px;">Home</a><span>/</span>Pricing</div>
    <div class="section-badge" style="background:#152B47;border:1px solid rgba(255,255,255,0.85);color:#FFFFFF;">Transparent Pricing</div>
    <h1 style="color:#FFFFFF;">Transparent pricing. <span class="accent" style="color:#FFFFFF;">Roadmap clearly marked.</span></h1>
    <p style="color:#FFFFFF;">The average fragmented management stack costs $25–30 per seat per month — across tools that share no data. Cadence self-serve access starts through the live signup funnel, with roadmap capabilities clearly labeled below.</p>
  </div>
</div>

<section class="section section-light">
  <div class="container">
    <div class="signup-notice">
      <div class="signup-notice-icon" aria-hidden="true"></div>
      <div class="signup-notice-text">
        <strong>Self-serve access is live:</strong> Essentials and Professional start through the Cadence signup funnel. Enterprise remains sales-led for security review, procurement, and custom rollout planning.
      </div>
    </div>
    <div class="pricing-grid">
      <div class="pricing-card">
        <div class="pricing-tier-name">Essentials</div>
        <div class="pricing-tagline">The live management operating plane for teams building their foundation.</div>
        <div class="price-big"><sup>$</sup>12</div>
        <div class="price-period">per seat / month, billed annually</div>
        <div class="best-for"><strong>Best for:</strong> Organizations of 50–300 people building systematic management practices.</div>
        <a href={g1SignupHref('essentials', 'pricing_cta', { tier: 'essentials' })} class="pricing-cta-btn cta-outline-btn">Start free trial</a>
        <div class="pricing-divider"></div>
        <div class="includes-label">Includes</div>
        <ul class="features-list">
          <li><span class="check-y"></span> 1:1 Management Engine — structured agendas and follow-through</li>
          <li><span class="check-y"></span> Goals &amp; OKR Tracking — list, create, update, and progress workflows</li>
          <li><span class="check-y"></span> Recognition feed and posting</li>
          <li><span class="check-y"></span> Pulse survey response collection and aggregate analytics</li>
          <li><span class="check-y"></span> Job Architecture — import, versioned role definitions, level context, and role assignment</li>
          <li><span class="check-y"></span> AI meeting summaries</li>
          <li><span class="check-y"></span> Manager-lane AI coaching</li>
          <li class="roadmap-li">Standard integrations beyond current product plumbing — preview until tenant proof is attached</li>
        </ul>
      </div>
      <div class="pricing-card featured">
        <div class="pricing-badge-pill">⭐ Most Popular</div>
        <div class="pricing-tier-name">Professional</div>
        <div class="pricing-tagline">Live intelligence workspace for mid-market People leaders.</div>
        <div class="price-big"><sup>$</sup>24</div>
        <div class="price-period">per seat / month, billed annually</div>
        <div class="best-for"><strong>Best for:</strong> Organizations of 100–1,000 people where the CHRO needs manager scorecard and org-health heatmap views.</div>
        <a href={g1SignupHref('professional', 'pricing_cta', { tier: 'professional' })} class="pricing-cta-btn cta-secondary-btn">Start trial</a>
        <div class="pricing-divider"></div>
        <div class="includes-label">Everything in Essentials, plus</div>
        <ul class="features-list">
          <li><span class="check-y"></span> 9-Box Talent Calibration</li>
          <li><span class="check-y"></span> Connected Agents (BYOA) — bring your own AI over MCP, with audit log</li>
          <li><span class="check-y"></span> ER Command Center — full case lifecycle</li>
          <li><span class="check-y"></span> Manager scorecard and org-health heatmap</li>
          <li><span class="check-y"></span> Personality working-style profile</li>
          <li class="roadmap-li">Personality woven into 1:1s and coaching — roadmap</li>
          <li class="roadmap-li">Turnover prediction — not included in current self-serve access</li>
          <li><span class="check-y"></span> Employee-lane AI coaching</li>
          <li class="roadmap-li">L2 manager chain dashboard — preview until tenant proof is attached</li>
          <li><span class="check-y"></span> Advanced analytics and reporting</li>
          <li><span class="check-y"></span> Priority support</li>
        </ul>
      </div>
      <div class="pricing-card">
        <div class="pricing-tier-name">Enterprise</div>
        <div class="pricing-tagline">Enterprise security, compliance, integrations, and dedicated support for your agreed workspace scope.</div>
        <div class="price-custom">Custom</div>
        <div class="price-period">500+ seats · Annual contract</div>
        <div class="best-for"><strong>Best for:</strong> Organizations with 500+ employees or complex enterprise security requirements.</div>
        <a href="mailto:demo@cadencehr.ai?subject=Enterprise%20pricing" class="pricing-cta-btn cta-outline-btn">Talk to us</a>
        <div class="pricing-divider"></div>
        <div class="includes-label">Everything in Professional, plus</div>
        <ul class="features-list">
          <li><span class="check-y"></span> Enterprise SSO (OIDC)</li>
          <li><span class="check-y"></span> SAML SSO</li>
          <li class="roadmap-li">SCIM provisioning — Q4 roadmap</li>
          <li class="roadmap-li">Custom HRIS integrations beyond current admin import — enterprise roadmap</li>
          <li><span class="check-y"></span> Configurable data retention</li>
          <li><span class="check-y"></span> Dedicated Customer Success Manager</li>
          <li class="roadmap-li">SLA-backed uptime guarantees — contract-dependent GA target</li>
          <li><span class="check-y"></span> Data Processing Agreement (DPA)</li>
          <li><span class="check-y"></span> Custom onboarding and training</li>
        </ul>
      </div>
    </div>
    <div class="trust-section">
      <div class="trust-panel">
        <h3>Buy without wondering what happens to your people data.</h3>
        <div class="trust-grid">
          <div class="trust-card">
            <strong>Human decisions stay human.</strong>
            <p>Cadence surfaces patterns, coaching prompts, and review queues. It does not decide discipline, promotion, termination, compensation, or performance ratings.</p>
          </div>
          <div class="trust-card">
            <strong>Your company data is not used for model training by default.</strong>
            <p>Customer audio, transcripts, coaching outputs, survey responses, ER records, performance records, recognition records, and scorecard telemetry are not used to train, fine-tune, or improve Cadence AI models by default, unless your company explicitly agrees in writing.</p>
          </div>
          <div class="trust-card">
            <strong>Security review has a path.</strong>
            <p>Essentials and Professional teams can start with standard terms. If you need SSO/SAML, procurement review, a security questionnaire, or enterprise DPA negotiation, route to the Enterprise path.</p>
          </div>
        </div>
        <div class="trust-compact">
          <span>Human-reviewed AI</span>
          <span>No customer-data model training by default</span>
          <span>DPA available for review</span>
          <span>SOC 2 readiness in progress</span>
        </div>
      </div>
      <aside class="checkout-panel">
        <div>
          <h3>What you get after checkout</h3>
          <p>Cadence provisions your workspace, invites your first admins, and guides your team into the first 1:1 setup flow. Your managers still lead the conversations. Cadence provides the operating system around them: agendas, action items, goals, recognition, coaching prompts, and the Culture Scorecard signals that help leaders see where management is working.</p>
          <div class="checkout-note">AI outputs are decision-support. Formal people decisions stay with accountable humans.</div>
        </div>
        <p style="margin-top:18px;margin-bottom:0;">Need SSO/SAML, procurement review, a custom DPA, or more than 300 seats? Use the Enterprise path so the right human review happens before purchase.</p>
      </aside>
    </div>
    <div class="enterprise-route-panel">
      <div>
        <h3>Some purchases should not be self-serve.</h3>
        <p>If your team needs SSO/SAML, procurement review, security questionnaires, custom legal review, regulated privacy review, custom privacy deployment, or more than 300 seats, Cadence routes you to an Enterprise path before checkout. Regulated or custom privacy deployments use the Enterprise/legal review path before activating covered features.</p>
        <p style="margin-top:8px;">Enterprise-shaped intent always routes to a human-led path. Self-serve is for standard Essentials and Professional starts.</p>
      </div>
      <a href={withBase('/beta')} class="btn btn-white btn-lg">Talk to Cadence</a>
    </div>
    <div class="savings-row">
      <div class="savings-text">Cadence Professional at 100 seats: <strong>$28,800/year</strong> &nbsp;·&nbsp; Comparable fragmented stack: <span class="strikethrough">$36,000+/year</span> &nbsp; <span class="highlight">Savings estimates exclude roadmap capabilities that are not current deliverables.</span></div>
      <a href="#comparison" class="savings-link">See full comparison →</a>
    </div>
  </div>
</section>

<section class="section section-white" id="comparison">
  <div class="container">
    <div class="center">
      <div class="section-badge">Feature Comparison</div>
      <h2 class="section-headline">Every feature, every tier.</h2>
      <p class="section-subhead">We believe in showing you exactly what you get today, and what is still roadmap. No fine print.</p>
    </div>
    <div class="compare-wrap">
      <div class="compare-head">
        <div class="feature-col">Feature</div>
        <div>Essentials</div>
        <div>Professional</div>
        <div>Enterprise</div>
      </div>
      <div class="compare-row"><div class="compare-group">Core Management</div></div>
      <div class="compare-row"><div class="compare-feature-name">1:1 Management Engine</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div></div>
      <div class="compare-row"><div class="compare-feature-name">AI meeting summaries</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div></div>
      <div class="compare-row"><div class="compare-feature-name">Private AI coaching — manager</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div></div>
      <div class="compare-row"><div class="compare-feature-name">Private AI coaching — employee</div><div class="compare-no">No</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div></div>
      <div class="compare-row"><div class="compare-group">Goals &amp; OKRs</div></div>
      <div class="compare-row"><div class="compare-feature-name">OKR cascading (Company → Team → IC)</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div></div>
      <div class="compare-row"><div class="compare-feature-name">Live goal context in 1:1 sidebar (preview)</div><div class="compare-partial">Preview</div><div class="compare-partial">Preview</div><div class="compare-partial">Preview</div></div>
      <div class="compare-row"><div class="compare-feature-name">AI goal health recommendations (preview)</div><div class="compare-no">No</div><div class="compare-partial">Preview</div><div class="compare-partial">Preview</div></div>
      <div class="compare-row"><div class="compare-group">Personality Intelligence</div></div>
      <div class="compare-row"><div class="compare-feature-name">Consented instrument + own working-style profile</div><div class="compare-no">No</div><div class="compare-yes">Included</div><div class="compare-yes">Included</div></div>
      <div class="compare-row"><div class="compare-feature-name">Team working-style view (roadmap)</div><div class="compare-no">No</div><div class="compare-no">Coming</div><div class="compare-no">Coming</div></div>
